module act.selfevolve@0.1

use tool act@1 as act
use tool actc@1 as actc
use tool github@2 as gh
use model codegen@2026-06 as coder

type Repo = {
  owner: String,
  name: String,
}

// 0.0–1.0, enforced by the refinement type.
type Score = Decimal where 0.0 <= self <= 1.0

// A candidate Act program generated by the model.
type Candidate = {
  source: String,
  task_name: String,
  rationale: String,
  self_score: Score,
}

// The verdict from the self-hosted checker (Rust oracle) on a candidate.
type CheckVerdict = {
  ok: Bool,
  diagnostics: String,
}

// The verdict from the self-hosted runtime (act.run_task) on a candidate.
type RunVerdict = {
  ok: Bool,
  output: String,
}

// A fully evaluated candidate: check + run + final rating.
type EvalVerdict = {
  candidate: Candidate,
  check: CheckVerdict,
  run: RunVerdict,
  score: Score,
}

type SelfEvolveResult = {
  best: Candidate,
  score: Score,
  pr_url: String,
}

type SelfEvolveError =
  | no_candidate(reason: String)
  | tool_failed(tool: String, cause: String)

// The headline example: Act writes an Act program, checks it with its own
// checker, runs it with its own runtime, verifies each step with its own
// verifier, and opens a PR — all under budgets, capabilities, and a policy
// that forbids merging/pushing and requires a human. The entire pipeline is
// self-hosted: every model call is gated by the builtin `verify` task (an Act
// program), the checker is `actc.diagnose` (the Rust oracle, called from Act),
// and the run is `act.run_task` (Act executing Act). Evidence is recorded for
// replay so a postmortem or eval can reconstruct the decision later.
//
// This single task exercises: infer + accept (x5, self-hosted verifier),
// decide (weighted rating), await all (parallel generation), await map
// (parallel evaluation), actc.diagnose (self-hosted checker), act.run_task
// (self-hosted runtime), trace/replay (evidence), defer compensate (cleanup),
// policy_expect (authority), budgets (4 metrics), capabilities (3), refinement
// types (Score), and a typed error union.
task self_evolve(repo: Repo, goal: String) -> Result<SelfEvolveResult, SelfEvolveError>
  effects [act.read, act.write, actc.read, gh.read, gh.write, model]
  needs [
    cap act.run_task,
    cap actc.read,
    cap gh.pull_request.create(repo),
  ]
  budget {
    wall_time <= 20m,
    tokens <= 200_000,
    cost <= 10.00,
    tool_calls <= 80,
  }
  policy_expect {
    may gh.create_pull_request
    may act.run_task
    may actc.read
    must_not gh.merge_pull_request
    must_not gh.push_branch where true
    require_human when true
  }
{
  // Generate two candidate programs in parallel. Each `infer` is gated by the
  // self-hosted verifier — a `return` inside an `await all` branch propagates
  // out as the task's result, so a verifier rejection aborts the whole run
  // with a typed error.
  let candidates = await all {
    a: infer Candidate using coder {
      goal: "Write an Act task that solves this goal. Return valid Act source."
      input: { goal: goal }
      constraints: [
        "Return valid Act source in the `source` field.",
        "Name the entry task in `task_name`.",
        "Explain the approach in `rationale`.",
        "self_score is your confidence 0.0-1.0.",
      ]
    } accept {
      confidence >= 0.6,
    } else {
      return err(no_candidate("candidate A rejected by verifier"))
    },
    b: infer Candidate using coder {
      goal: "Write a different Act task solving the same goal with a distinct approach."
      input: { goal: goal }
      constraints: [
        "Return valid Act source in the `source` field.",
        "Use a different strategy than the obvious one.",
      ]
    } accept {
      confidence >= 0.6,
    } else {
      return err(no_candidate("candidate B rejected by verifier"))
    },
  }

  // Evaluate each candidate in parallel: check with the Rust oracle, run with
  // the Act runtime, then rate. All three are self-hosted — Act checking and
  // running Act. A failure in any phase rates 0.0 but does not abort the
  // others; the eval must be total.
  let evals = await map c in [candidates.a, candidates.b] parallel 2 limit 2 {
    evaluate(c)
  }

  // Decide the best by weighted rating (correctness first, then self-confidence).
  let best = decide EvalVerdict from evals
    score by [
      0.7: score desc,
      0.3: candidate.self_score desc,
    ]
    accept score >= 0.5
    else return err(no_candidate("no candidate cleared the score threshold"))

  check best.score >= 0.7 else {
    return err(no_candidate("best score below 0.7"))
  }

  // Open a PR with the winning program. Compensate by closing if anything
  // after this point fails — never leave an unreviewed branch behind.
  let pr = try gh.create_pull_request(
    repo: repo,
    branch: "agent/self-evolve",
    title: best.candidate.rationale,
    body: best.candidate.source,
  )
  defer compensate {
    gh.close_pull_request(repo: repo, branch: "agent/self-evolve")
  }

  // Record evidence for replay: the winning program, its eval, and the trace
  // of running it. A postmortem or eval harness can replay this later.
  trace "self_evolve" {
    goal: goal,
    best_source: best.candidate.source,
    best_score: best.score,
    check_diagnostics: best.check.diagnostics,
    run_output: best.run.output,
  }

  return ok({
    best: best.candidate,
    rating: best.score,
    pr_url: pr,
  })
}

// Evaluate one candidate: check (Rust oracle) + run (Act runtime) + rate.
// Every infer here is also gated by the self-hosted verifier, so the rating
// itself is verified — not just the model's self-report.
proc evaluate(c: Candidate) -> EvalVerdict
  effects [act.read, act.write, actc.read, model]
{
  // Self-hosted checker: Act runs the Rust checker on Act source.
  let diag_json = try actc.diagnose(source: c.source)
  let check = infer CheckVerdict using coder {
    goal: "Interpret the checker diagnostics JSON. ok is true if there are no Error-severity diagnostics."
    input: check
  }

  // Self-hosted runtime: Act runs the candidate Act program. If it doesn't
  // check clean we still attempt the run and rate 0.0 — the eval is total.
  let run = try act.run_task(
    module_src: c.source,
    task_name: c.task_name,
    args: "{}",
  )
  let run = infer RunVerdict using coder {
    goal: "Interpret the run result. ok is true if the result is ok(...)."
    input: run
  }

  // Final rating combines check + run + self-confidence.
  let score = infer Score using coder {
    goal: "Rate this candidate 0.0-1.0. 1.0 if it checks clean AND runs ok AND addresses the goal. 0.0 if it fails to check or run."
    input: {
      candidate: c,
      check: checker,
      run: runner,
    }
  } accept {
    confidence >= 0.5,
  }

  return {
    candidate: c,
    check: checker,
    run: runner,
    score: score,
  }
}

// Replay the recorded evidence and assert the best rating cleared the bar.
// An eval harness or postmortem drives this to reconstruct the decision.
eval "replay_self_evolve" {
  let t = replay trace("self_evolve")
  require t.best_score >= 0.7
}
